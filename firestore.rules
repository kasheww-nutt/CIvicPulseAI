rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Real-time cases rules
    match /cases/{caseId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      // Allow deletion for administrators or authorized users
      allow delete: if isAuthenticated();
    }

    // Real-time notifications rules
    match /notifications/{notificationId} {
      // Users can only read, write, or update notifications meant for their specific UID
      allow read, create, update, delete: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
  }
}
